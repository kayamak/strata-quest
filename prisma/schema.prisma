generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NextAuth テーブル

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  playerProfile  PlayerProfile?
  vocabularyUnlocks VocabularyUnlock[]
  playSessions   PlaySession[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ゲームエンティティ

model PlayerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  level           Int      @default(1)
  totalXp         Int      @default(0)
  abstractPower   Int      @default(0)
  specificPower   Int      @default(0)
  structureSense  Int      @default(0)
  vocabularyLevel Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VocabularyNode {
  id                  String   @id @default(cuid())
  word                String   @unique
  japaneseMeaning     String
  definition          String
  abstractionLevel    Int
  difficulty          Int
  parentId            String?
  requiredPlayerLevel Int      @default(1)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  parent   VocabularyNode?  @relation("VocabularyHierarchy", fields: [parentId], references: [id])
  children VocabularyNode[] @relation("VocabularyHierarchy")

  unlocks   VocabularyUnlock[]
  questions Question[]
}

model VocabularyUnlock {
  id               String   @id @default(cuid())
  userId           String
  vocabularyNodeId String
  unlockedAt       DateTime @default(now())

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabularyNode VocabularyNode @relation(fields: [vocabularyNodeId], references: [id], onDelete: Cascade)

  @@unique([userId, vocabularyNodeId])
}

model Quest {
  id            String   @id @default(cuid())
  title         String
  description   String
  questType     String
  requiredLevel Int      @default(1)
  difficulty    Int
  baseXpReward  Int
  questionCount Int
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  questions    Question[]
  playSessions PlaySession[]
}

model Question {
  id                 String   @id @default(cuid())
  questId            String
  questionText       String
  questionType       String
  targetVocabularyId String
  explanation        String
  sortOrder          Int
  timeLimitSeconds   Int      @default(30)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  quest          Quest          @relation(fields: [questId], references: [id], onDelete: Cascade)
  targetVocabulary VocabularyNode @relation(fields: [targetVocabularyId], references: [id])
  answerOptions  AnswerOption[]
  questionAnswers QuestionAnswer[]
}

model AnswerOption {
  id               String   @id @default(cuid())
  questionId       String
  text             String
  isCorrect        Boolean
  vocabularyNodeId String?
  sortOrder        Int
  createdAt        DateTime @default(now())

  question        Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionAnswers QuestionAnswer[]
}

model PlaySession {
  id             String    @id @default(cuid())
  userId         String
  questId        String
  status         String    @default("IN_PROGRESS")
  totalXpEarned  Int       @default(0)
  correctAnswers Int       @default(0)
  totalQuestions Int
  maxCombo       Int       @default(0)
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  quest           Quest            @relation(fields: [questId], references: [id])
  questionAnswers QuestionAnswer[]
}

model QuestionAnswer {
  id                  String   @id @default(cuid())
  playSessionId       String
  questionId          String
  selectedOptionId    String?
  isCorrect           Boolean
  xpEarned            Int
  responseTimeMs      Int
  comboCountAtAnswer  Int      @default(0)
  createdAt           DateTime @default(now())

  playSession    PlaySession  @relation(fields: [playSessionId], references: [id], onDelete: Cascade)
  question       Question     @relation(fields: [questionId], references: [id])
  selectedOption AnswerOption? @relation(fields: [selectedOptionId], references: [id])
}
